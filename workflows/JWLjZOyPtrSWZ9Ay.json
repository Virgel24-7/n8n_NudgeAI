    },
    {
      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "let text = $('Update to processing').item.json.followUpMessage;\n\nconst html = text\n  .replace(/\\/n/g, '<br>')\n  .replace(/\\n/g, '<br>');\n\nreturn {\n  htmlMessage: html\n};"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
