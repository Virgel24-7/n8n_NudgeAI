    {
      "parameters": {
        "jsCode": "const inbox = $input.all()\n\nconst reply = inbox.find(m =>\n  m.json.conversationId === $('Update to processing').first().json.conversationId &&\n  m.json.sender.emailAddress.address !== $('Update to processing').first().json.sender\n);\n\nreturn {\n  hasReply: !!reply\n};"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        2016,
        -320
      ],
      "id": "ce40b960-3a4b-4db8-ade4-92e4cb51efd2",
